{
  "name": "restaurant-website",
  "version": "1.0.0",
  "scripts": {
    "build:tailwind": "npx tailwindcss -i ./src/input.css -o ./src/output.css",
    "build:sass": "sass src/styles.scss src/styles.css",
    "build": "npm run build:tailwind && npm run build:sass",
    "watch": "concurrently \"npm run build:tailwind -- --watch\" \"sass --watch src/styles.scss src/styles.css\""
  },
  "dependencies": {
    "@tailwindcss/cli": "^4.2.2",
    "tailwindcss": "^4.2.2"
  },
  "devDependencies": {
    "sass": "^1.72.0",
    "concurrently": "^8.2.2"
  }
}
